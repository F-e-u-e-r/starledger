{
  "name": "@starred/discovery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts.ts",
      "default": "./src/contracts.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "start": "tsx src/cli.ts",
    "generate:schemas": "node --import tsx src/generate-schemas.ts"
  },
  "dependencies": {
    "@starred/github-client": "workspace:*",
    "@starred/schema": "workspace:*",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
