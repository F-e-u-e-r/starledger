{
  "$ref": "#/definitions/DiscoveryCandidatesMeta",
  "definitions": {
    "DiscoveryCandidatesMeta": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "number",
          "const": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "dataset_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "generator_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "schema_version",
        "generated_at",
        "dataset_sha",
        "candidate_count",
        "source_count",
        "generator_version"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "https://json-schema.org/draft/2019-09/schema#"
}
